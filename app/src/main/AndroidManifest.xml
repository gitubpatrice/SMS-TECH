<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- SMS / MMS core permissions -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.WRITE_SMS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.RECEIVE_MMS" />
    <uses-permission android:name="android.permission.RECEIVE_WAP_PUSH" />
    <uses-permission android:name="android.permission.BROADCAST_WAP_PUSH"
        tools:ignore="ProtectedPermissions" />

    <!-- Contacts -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Phone state (dual SIM) -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- v1.2.7 audit S8 : USE_FULL_SCREEN_INTENT retiré (privilégiée Android 14+,
         auto-révoquée par Play Console hors cas calling/alarms, et aucune utilisation
         côté code — vérifié par grep, aucun setFullScreenIntent appelé). -->


    <!-- Biometric -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Voice MMS (audio recording attached to outgoing MMS) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- v1.10.0 — Mode urgence : géoloc pour SMS d'urgence (single-fix uniquement,
         pas de tracking continu). ACCESS_COARSE_LOCATION en filet pour devices/OEM
         où FINE est durci. Permission opt-in : si refusée par l'user, le SMS d'urgence
         est envoyé sans coordonnées (graceful degradation). Aucune utilisation
         background. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- v1.3.5 G3 audit fix — SCHEDULE_EXACT_ALARM + USE_EXACT_ALARM retirées :
         l'envoi planifié passe exclusivement par WorkManager.enqueueUniqueWork (cf.
         ScheduledMessageScheduler) qui n'a PAS besoin de ces permissions. Elles
         étaient des permissions orphelines générant un Play Console warning + une
         révocation potentielle Android 14+. Aucun usage de AlarmManager.setExact*
         vérifié par grep avant retrait. -->

    <!-- MMS HTTP only -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- v1.3.5 G3 audit fix — CHANGE_NETWORK_STATE retirée : aucun appel
         ConnectivityManager.setMobileDataEnabled / requestNetwork* dans l'app.
         INTERNET + ACCESS_NETWORK_STATE suffisent pour le transport MMS. -->

    <!-- Foreground service for long migration/backup tasks -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Boot completed for scheduled messages -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Telephony features (not strictly required - app works on tablets without SIM for reading backups) -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- Queries (Android 11+ package visibility) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="smsto" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="tel" />
        </intent>
        <!-- v1.7.1 — ACTION_PROCESS_TEXT pour la traduction externe (remplace
             la feature ML Kit retirée en v1.7.0). Permet à l'utilisateur de
             choisir son app de traduction installée (Google Translate, DeepL,
             Aves Translate, LibreTranslate…) — SMS Tech délègue au système
             plutôt que de bundler un traducteur interne. `resolveActivity`
             côté Kotlin nécessite cette déclaration sur Android 11+ pour
             vérifier qu'au moins une app handle l'intent. -->
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        <package android:name="com.android.contacts" />
    </queries>

    <application
        android:name=".MainApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="false"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.SmsTech.Splash"
        tools:targetApi="34">

        <!-- Single Activity host -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|uiMode|locale|layoutDirection|keyboard|keyboardHidden|navigation|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SmsTech.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <!-- Default SMS app — Tab "Texto" entry points -->
            <intent-filter>
                <action android:name="android.intent.action.SENDTO" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>

            <!-- View entry -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>

            <!-- v1.3.3 bug #4 — apparaît dans le chooser système "Partager" depuis la
                 Galerie, le navigateur, les apps de fichiers, etc. Le user peut envoyer
                 une image / vidéo / fichier directement vers une conversation SMS Tech.
                 MainActivity intercepte l'intent ACTION_SEND (extra EXTRA_STREAM) /
                 ACTION_SEND_MULTIPLE et ouvre le picker de conversation. -->
            <!-- v1.3.3 Z6 audit fix — restreindre aux types réellement supportés par
                 l'app : pas de `text/*` ni `application/*` larges qui captaient text/html,
                 application/x-www-form-urlencoded etc. (l'app les routait en FILE catch-all
                 sans rendu propre). Restriction au strict utile. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
                <data android:mimeType="audio/*" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="text/x-vcard" />
                <data android:mimeType="text/vcard" />
                <data android:mimeType="application/pdf" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
                <data android:mimeType="video/*" />
            </intent-filter>
        </activity>

        <!-- 1) SMS receiver (must be enabled by default SMS app) -->
        <receiver
            android:name=".system.receiver.SmsDeliverReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>

        <!-- 2) MMS WAP_PUSH receiver -->
        <receiver
            android:name=".system.receiver.MmsWapPushReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_WAP_PUSH">
            <intent-filter>
                <action android:name="android.provider.Telephony.WAP_PUSH_DELIVER" />
                <data android:mimeType="application/vnd.wap.mms-message" />
            </intent-filter>
        </receiver>

        <!-- 3) Sent / Delivered (internal broadcasts) -->
        <receiver
            android:name=".system.receiver.SmsSentReceiver"
            android:exported="false" />
        <receiver
            android:name=".system.receiver.SmsDeliveredReceiver"
            android:exported="false" />
        <receiver
            android:name=".system.receiver.MmsSentReceiver"
            android:exported="false" />
        <receiver
            android:name=".system.receiver.MmsDownloadedReceiver"
            android:exported="false" />

        <!-- 4) Boot — reschedule scheduled messages.
             v1.6.1 audit SEC-11 clarification: les trois actions déclarées sont des
             "protected broadcasts" AOSP — seul le framework (ActivityManagerService) peut
             les émettre. Le `android:permission="RECEIVE_BOOT_COMPLETED"` ci-dessous est
             une permission "normal" (pas "signature") : elle peut être détenue par
             n'importe quelle app et n'ajoute donc PAS de protection effective contre les
             apps tierces — la vraie protection vient du statut protected-broadcast des
             actions BOOT_COMPLETED / LOCKED_BOOT_COMPLETED / USER_UNLOCKED, énumérées
             dans la liste AOSP `frameworks/base/core/res/AndroidManifest.xml`. On conserve
             la permission pour cohérence avec la convention historique et pour signaler
             l'intention au lecteur ; ne pas la retirer SANS également remplacer par un
             check `isOrderedBroadcast()` ou un mécanisme équivalent.
             QUICKBOOT_POWERON (action HTC legacy non-protégée) retirée. -->
        <receiver
            android:name=".system.receiver.BootReceiver"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <!-- Audit M-11: rattrapage des SMS arrivés en direct-boot avant que
                     l'utilisateur ne déverrouille le téléphone pour la première fois.
                     ACTION_USER_UNLOCKED est un protected-broadcast AOSP (cf. note ci-dessus). -->
                <action android:name="android.intent.action.USER_UNLOCKED" />
            </intent-filter>
        </receiver>

        <!-- 5) Notification actions: Reply / MarkAsRead -->
        <receiver
            android:name=".system.notifications.NotificationActionReceiver"
            android:exported="false" />

        <!-- v1.12.0 — Raccourci urgence (notification persistante lock-screen).
             `exported=false` : seul SMS Tech peut déclencher les actions
             SHORTCUT_TRIGGER_EMERGENCY / SHORTCUT_DIAL_112 via PendingIntent
             interne. Une app tierce ne peut pas forger un Intent et déclencher
             le SMS d'urgence. -->
        <receiver
            android:name=".system.receiver.EmergencyShortcutReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.filestech.sms.SHORTCUT_TRIGGER_EMERGENCY" />
                <action android:name="com.filestech.sms.SHORTCUT_DIAL_112" />
                <action android:name="com.filestech.sms.SHORTCUT_DIAL_POLICE" />
            </intent-filter>
        </receiver>

        <!-- 6) HeadlessSmsSendService — required for default SMS app -->
        <service
            android:name=".system.service.HeadlessSmsSendService"
            android:exported="true"
            android:permission="android.permission.SEND_RESPOND_VIA_MESSAGE">
            <intent-filter>
                <action android:name="android.intent.action.RESPOND_VIA_MESSAGE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </service>

        <!-- 7) Long-running migration/backup foreground service via WorkManager -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:replace="android:foregroundServiceType" />

        <!-- 7-bis) v1.3.10 — Foreground service permanent OPT-IN (Réglages → Avancé →
             "Mode résistant Xiaomi/Huawei"). Empêche MIUI/HyperOS/EMUI de killer le
             processus SMS Tech en arrière-plan, ce qui débloque la réception WAP push
             des MMS + la pose de notifications SMS sur les ROMs qui whitelistent
             uniquement Google Messages / Mi Messages.
             android:exported="false" : aucune surface IPC publique, démarré uniquement
             en interne via [KeepAliveService.start].
             android:foregroundServiceType="dataSync" : requis Android 14+ (API 34+).
             android:stopWithTask="false" : le service survit au swipe-out de l'app
             depuis les récents — c'est tout le point pour résister à MIUI. -->
        <service
            android:name=".system.service.KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

        <!-- 8) WorkManager init — let Hilt take over -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- 9) FileProvider — partage des PJ MMS / exports -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>
    </application>
</manifest>
