<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmsTech" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/md_theme_dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- v1.14.5 — logo carré sms_tech_icon, circle bg matches window bg (dark). -->
    <style name="Theme.SmsTech.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_theme_dark_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/md_theme_dark_background</item>
        <item name="postSplashScreenTheme">@style/Theme.SmsTech</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>
