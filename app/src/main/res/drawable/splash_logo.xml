<?xml version="1.0" encoding="utf-8"?>
<!--
  v1.14.5 — Drawable splash. Wrap le logo carré sms_tech_icon dans un inset
  pour qu'il rentre dans la zone safe 192dp imposée par Android 12+ SplashScreen
  API. Combiné avec windowSplashScreenIconBackgroundColor = couleur fond fenêtre,
  le masque circulaire système devient invisible à l'œil et le logo apparaît
  carré comme demandé.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/sms_tech_icon"
    android:inset="20%" />
