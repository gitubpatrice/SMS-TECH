<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base app theme (Compose uses MaterialTheme; this is only for the splash window) -->
    <style name="Theme.SmsTech" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/md_theme_light_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen (androidx.core.splashscreen compat for API 26-30) -->
    <!--
        v1.14.7 — icône transparente : Android 12+ impose un masque circulaire
        autour de l'icône splash. En fournissant un drawable transparent, le
        cercle est invisible et seul le fond unie flashe brièvement avant que
        la Compose SplashScreen (fade-in) ou l'Activity ne prenne la main.
        Élimine le rond qui cachait le logo carré aux ouvertures suivantes.
    -->
    <style name="Theme.SmsTech.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_theme_light_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.SmsTech</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>
</resources>
