    <!-- About -->
    <string name="about_title">About</string>
    <string name="about_tagline_short">Modern, private SMS &amp; MMS for Android.</string>
    <string name="about_values_title">Why this app</string>
    <string name="about_value_private">Privacy first</string>
    <string name="about_value_private_body">No ads, no analytics, no third-party SDKs.</string>
    <string name="about_value_quiet">Quiet design</string>
    <string name="about_value_quiet_body">Material 3, dynamic colors, AMOLED. Nothing flashy.</string>
    <string name="about_value_local">Local-first</string>
    <string name="about_value_local_body">Everything stays on your device. The database is encrypted at rest.</string>
    <string name="about_value_open">Open source</string>
    <string name="about_value_open_body">Apache 2.0. Auditable. Contributions welcome.</string>
    <string name="about_permissions_title">Permissions we use</string>
    <string name="about_security_title">Security &amp; limits</string>
    <string name="about_security_body">SMS and MMS travel unencrypted across the carrier network — this is a protocol limitation, not a choice. SMS Tech only protects what is stored on your device. For end-to-end encrypted messaging, use Signal or Matrix.</string>
